// Dev-Debug.xcconfig
#include "Base.xcconfig"

// ─── Identity ─────────────────────────────────────────────────
PRODUCT_BUNDLE_IDENTIFIER = com.lumenshore.lumenlingo.dev
PRODUCT_NAME = LL Dev
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon

// ─── Environment ──────────────────────────────────────────────
LL_ENVIRONMENT = dev
LL_API_BASE_URL = https:/$()/api-dev.lumenlingo.com
LL_LOG_LEVEL = verbose

// ─── Clerk Auth ──────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY = pk_test_PLACEHOLDER_REPLACE_WITH_REAL_KEY
CLERK_INSTANCE_URL =

// ─── RevenueCat ──────────────────────────────────────────────
REVENUECAT_API_KEY = appl_PLACEHOLDER_REPLACE_WITH_SANDBOX_KEY

// ─── Debug Settings ───────────────────────────────────────────
SWIFT_OPTIMIZATION_LEVEL = -Onone
DEBUG_INFORMATION_FORMAT = dwarf
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG DEV
ENABLE_TESTABILITY = YES
