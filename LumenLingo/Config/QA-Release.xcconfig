// QA-Release.xcconfig
#include "Base.xcconfig"

// ─── Identity ─────────────────────────────────────────────────
PRODUCT_BUNDLE_IDENTIFIER = com.lumenshore.lumenlingo.qa
PRODUCT_NAME = LL QA
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon

// ─── Environment ──────────────────────────────────────────────
LL_ENVIRONMENT = qa
LL_API_BASE_URL = https:/$()/api-qa.lumenlingo.com
LL_LOG_LEVEL = debug

// ─── Clerk Auth ──────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY = pk_test_PLACEHOLDER_REPLACE_WITH_REAL_KEY
CLERK_INSTANCE_URL =

// ─── RevenueCat ──────────────────────────────────────────────
REVENUECAT_API_KEY = appl_PLACEHOLDER_REPLACE_WITH_SANDBOX_KEY

// ─── Release Settings ─────────────────────────────────────────
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = wholemodule
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
VALIDATE_PRODUCT = YES
SWIFT_ACTIVE_COMPILATION_CONDITIONS = QA
ENABLE_TESTABILITY = YES
