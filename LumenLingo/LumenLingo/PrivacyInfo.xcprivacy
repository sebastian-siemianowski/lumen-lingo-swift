<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App does not track users across apps/websites per ATT definition -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No tracking domains — app makes zero network requests to tracking services -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Required Reason APIs used by the app -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- UserDefaults: used for UI state, preferences, session tracking -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>

	<!-- Collected data types: NONE — all data stays on-device -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
</dict>
</plist>
